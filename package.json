{
  "name": "angular-jest-selective-demo",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest --config jest.config.js --passWithNoTests",
    "test:watch": "jest --config jest.config.js --watch",
    "test:all": "jest --config jest.config.js",
    "test:changed": "node ./scripts/run-changed-tests.mjs",
    "test:ci:dev": "node ./scripts/run-tests-for-env.mjs dev",
    "test:ci:stg": "node ./scripts/run-tests-for-env.mjs stg",
    "test:ci:prod": "node ./scripts/run-tests-for-env.mjs prod",
    "test:demo:all": "node ./scripts/run-tests-for-env.mjs all",
    "test:demo:changed": "node ./scripts/run-tests-for-env.mjs dev",
    "generate:slow-suite": "node ./scripts/generate-slow-suite.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^17.3.0",
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/forms": "^17.3.0",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/router": "^17.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.17",
    "@angular/cli": "^17.3.17",
    "@angular/compiler-cli": "^17.3.0",
    "@types/jasmine": "~5.1.0",
    "@types/jest": "^29.5.14",
    "jasmine-core": "~5.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-preset-angular": "^14.6.2",
    "jsdom": "^22.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.4.2"
  }
}
